# Environment variables for TEMSA Entegrasyon Sistemi
# Copy this to .env.local and fill in your values

# Neon PostgreSQL - Connection string with pooling (for queries)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Neon PostgreSQL - Direct connection (for migrations)
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# JWT Secret (generate a strong random string)
JWT_SECRET="change-this-to-a-strong-random-secret-min-32-chars"
